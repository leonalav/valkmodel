{
  "model_type": "valkmodel",
  "hidden_size": 768,
  "num_hidden_layers": 12,
  "num_heads": 6,
  "num_v_heads": 6,
  "head_dim": 96,
  "expand_v": 2.0,
  "max_position_embeddings": 272000,
  "max_training_seq_len": 2048,
  "hidden_ratio": 4,
  "hidden_act": "swish",
  "norm_eps": 1e-6,
  "initializer_range": 0.02,
  "vocab_size": 128256,
  "use_cache": true,
  "attn_mode": "chunk",
  "gdn_backend": "auto",
  "use_gate": true,
  "use_short_conv": true,
  "allow_neg_eigval": false,
  "conv_size": 4,
  "use_latent_state": true,
  "latent_state_dim": 384,
  "latent_state_layers": [5, 11],
  "use_jepa": true,
  "jepa_hidden_dim": 384,
  "jepa_loss_weight": 0.03,
  "jepa_min_horizon": 1,
  "jepa_max_horizon": 16,
  "use_latent_branching": true,
  "latent_branching_layers": [8],
  "num_branches": 4,
  "branch_value_temperature": 1.5,
  "branch_diversity_weight": 0.001,
  "branch_entropy_weight": 0.003
}
